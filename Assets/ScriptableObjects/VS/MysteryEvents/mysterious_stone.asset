  m_Name: mysterious_stone
  m_EditorClassIdentifier: ProjectAscendant.Core::ProjectAscendant.Core.MysteryEventSO
  EventId: mysterious_stone
  DisplayName: Mysterious Stone
  Icon: {fileID: 0}
  NarrativeText: A strangely glowing stone sits at the side of the path. It pulses
    with faint energy.
  Choices:
  - ChoiceText: Inspect it carefully
    OutcomeText: "The stone crumbles in your hands \u2014 inside is a shimmering
      item!"
    OutcomeMechanicsNote: Award a random Common or Uncommon Relic from the run pool.
  - ChoiceText: Leave it be
    OutcomeText: You step around it. Better not take chances.
    OutcomeMechanicsNote: No effect.
  GDDReference: "\xA73.1.14 | Relic reward or nothing."
