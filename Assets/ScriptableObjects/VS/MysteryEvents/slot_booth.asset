  m_Name: slot_booth
  m_EditorClassIdentifier: ProjectAscendant.Core::ProjectAscendant.Core.MysteryEventSO
  EventId: slot_booth
  DisplayName: Slot Booth
  Icon: {fileID: 0}
  NarrativeText: An ancient mechanical booth blocks the mountain path. Its lever
    looks well-worn.
  Choices:
  - ChoiceText: Pull the lever (costs 50 PD)
    OutcomeText: The machine whirs and clanks... something falls out!
    OutcomeMechanicsNote: 'Spend 50 PD. RNG outcome (seeded): 40% Consumable, 40%
      PD gain (+100), 20% Relic.'
  - ChoiceText: Walk past
    OutcomeText: You squeeze around the machine. Some mysteries are best left alone.
    OutcomeMechanicsNote: No effect.
  GDDReference: "\xA73.1.14 | Slot machine \u2014 gamble PD for item/PD/relic."
